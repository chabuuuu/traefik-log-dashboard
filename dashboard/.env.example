# --- Agent configuration (env-managed) ---
# Define one or more agents using indexed keys.
AGENT_1_NAME=Primary Agent
AGENT_1_URL=http://traefik-agent:5000
AGENT_1_TOKEN=replace-with-agent-token
# AGENT_2_NAME=Staging Agent
# AGENT_2_URL=http://staging-agent:5000
# AGENT_2_TOKEN=replace-with-staging-token

# Optional: JSON array alternative to AGENT_N_* variables.
# DASHBOARD_AGENTS_JSON=[{"id":"agent-env-primary","name":"Primary","url":"http://traefik-agent:5000","token":"replace-with-agent-token","location":"on-site"}]

# Optional: lock UI/API agent mutations (add/edit/delete/import)
DASHBOARD_AGENTS_ENV_ONLY=true

# --- Dashboard behavior ---
DASHBOARD_REFRESH_INTERVAL_MS=5000
DASHBOARD_MAX_LOGS_DISPLAY=1000
DASHBOARD_TRAFFIC_TOP_ITEMS_LIMIT=25
DASHBOARD_PARSER_TREND_WINDOW_MINUTES=30
SHOW_DEMO_PAGE=true
DASHBOARD_SKIP_INTRO=false
DASHBOARD_DENSITY=comfortable

# --- Server ---
PORT=3000
DATA_DIR=/data

# --- Alerts ---
# ALERTS_API_KEY=replace-with-api-key
ALERT_SCHEDULER_INTERVAL_MS=300000
ALERT_FETCH_LINES=5000
ALERT_ALLOW_PRIVATE_WEBHOOKS=false

# --- GeoIP lookup service ---
GEOIP_LOOKUP_ENABLED=true
GEOIP_PROVIDER_BASE_URL=https://ipwho.is
GEOIP_LOOKUP_TIMEOUT_MS=3500
GEOIP_LOOKUP_MAX_IPS=256
GEOIP_LOOKUP_CONCURRENCY=10
GEOIP_LOOKUP_CACHE_TTL_MS=3600000
GEOIP_LOOKUP_CACHE_MAX_ENTRIES=10000
